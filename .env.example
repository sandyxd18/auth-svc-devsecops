# ─────────────────────────────────────────────
# Auth Microservice — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/auth_db"

# JWT secret — use a long random string in production
# Generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT expiry duration (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN="1h"

# Server port
PORT=3000

# Node environment
NODE_ENV="development"

# Admin credentials for testing (change in production)
ADMIN_USERNAME: admin
ADMIN_PASSWORD: Admin@1234!

# Observability settings
SERVICE_NAME="auth-microservice"
SERVICE_VERSION="1.0.0"

# OTLP → Alloy (traces)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

# Loki
LOKI_HOST="http://localhost:3100"